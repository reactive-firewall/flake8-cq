# see https://gist.github.com/tekin/12500956bd56784728e490d8cef9cb81#file-gitattributes
# see https://github.com/git/git/blob/master/userdiff.c
# Configure custom hunk header patterns for some built-in languages and file formats
*.c text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-8 linguist-language=C
*.h text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-8 linguist-language=C
*.c++ text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-8
*.h++ text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-8
*.cpp text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-8
*.hpp text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-16
*.cc text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-16
*.hh text eol=lf diff=cpp merge=cpp working-tree-encoding=UTF-16
*.m text eol=lf diff=objc merge=objc working-tree-encoding=UTF-8
*.mm text eol=lf diff=objc merge=objc working-tree-encoding=UTF-16
*.cs diff=csharp merge=csharp
*.css text eol=lf diff=css merge=css working-tree-encoding=UTF-8
*.html diff=html
*.xhtml diff=html linguist-language=xml
*.ex diff=elixir
*.exs diff=elixir
*.go text eol=lf diff=golang merge=golang working-tree-encoding=UTF-8
*.php text eol=lf diff=php working-tree-encoding=UTF-8
*.pl text eol=lf diff=perl working-tree-encoding=UTF-8
*.py text eol=lf diff=python merge=python working-tree-encoding=UTF-8
*.pyc export-ignore diff=python -merge -filter -text linguist-generated=true
*.pyi export-ignore diff=python merge=python -filter -text working-tree-encoding=UTF-8 linguist-language=C
*.{make,[mM][aA][kK][eE]} text eol=lf diff=makefile working-tree-encoding=UTF-8 linguist-language=Makelang
*.rb diff=ruby
*.rake diff=ruby
*.rs text eol=lf diff=rust merge=rust
*.lisp diff=lisp
*.clisp text eol=lf diff=lisp merge=lisp working-tree-encoding=UTF-8
*.el diff=lisp
*.{yml,yaml} text eol=lf diff=ini working-tree-encoding=UTF-8 linguist-language=YAML

# see https://gist.github.com/ruediger/5647207#file-attributes
*.f diff=fortran merge=fortran
*.tex diff=tex
*.bib diff=bibtex

# TODO: see https://gist.github.com/ruediger/5647207?permalink_comment_id=5175698#gistcomment-5175698

# more rules
.DS_Store export-ignore -text linguist-generated=true
*.icns -text -filter -merge
"Icon\r" -text -merge linguist-language=UX
*~ export-ignore -filter linguist-generated=true
*.pbxproj text eol=lf diff=config
*.xcworkspacedata text eol=lf diff=html merge=html linguist-language=XML
*.xcscheme text eol=lf diff=xml merge=xml linguist-language=XML
*.plist text diff=xml merge=xml linguist-language=XML
*.bplist text -merge linguist-generated=true
*.xib text diff=xml merge=xml linguist-language=XML
*.{orderFile,[oO][rR][dD][eE][rR][fF][iI][lL][eE]} text eol=lf -filter working-tree-encoding=UTF-8
Makefile text eol=lf diff=makefile merge=makefile working-tree-encoding=UTF-8 linguist-language=Makelang
